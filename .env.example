# ═══════════════════════════════════════════════════════════════
# V-Content Creator — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.

# ── LLM Text Providers (LiteLLM supports 100+ models) ──
# You only need the API key for the models you want to use.
GEMINI_API_KEY=your_gemini_api_key_here
MOONSHOT_API_KEY=your_moonshot_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: ElevenLabs TTS (use --eleven flag to activate) ──
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVEN_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Channel Configuration ──
CHANNEL_NAME=My Channel
VIDEO_PREFIX=video
DEFAULT_TAGS=stories,narration,storytime

# ── Video Quality (high, medium, low, minimal) ──
VIDEO_QUALITY=high
