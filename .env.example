# ═══════════════════════════════════════════════════════════════
# V-Content Creator — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.

# ── Required: At least one text model API key ──
GEMINI_API_KEY=your_gemini_api_key_here
MOONSHOT_API_KEY=your_moonshot_api_key_here

# ── Optional: ElevenLabs TTS (use --eleven flag to activate) ──
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVEN_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Channel Configuration ──
CHANNEL_NAME=My Channel
VIDEO_PREFIX=video
DEFAULT_TAGS=stories,narration,storytime

# ── Video Quality (high, medium, low, minimal) ──
VIDEO_QUALITY=high
